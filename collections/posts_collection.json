{
	"info": {
		"name": "JSONPlaceholder Posts Collection",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Get All Posts",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Statut HTTP est 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/posts",
					"host": ["{{baseUrl}}"],
					"path": ["posts"]
				}
			},
			"response": []
		},
		{
			"name": "Create a Post",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Statut HTTP est 201 Created\", function () {",
							"    pm.response.to.have.status(201);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"Mon Post\",\n    \"body\": \"Contenu\",\n    \"userId\": 1\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/posts",
					"host": ["{{baseUrl}}"],
					"path": ["posts"]
				}
			},
			"response": []
		}
	]
}